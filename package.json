{
  "name": "poke-cli",
  "private": true,
  "type": "module",
  "bin": {
    "pokedex": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "test": "bun test",
    "test:related": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "fallow": "fallow --summary",
    "fallow:audit": "fallow audit --quiet",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun test && bun run verify:index && bun run build && bun run fallow",
    "generate:index": "bun run scripts/generate-index.ts",
    "verify:index": "bun run scripts/verify-index.ts",
    "ci": "bun run check",
    "openspec": "openspec"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@fission-ai/openspec": "^1.4.1",
    "@types/bun": "^1.3.14",
    "fallow": "^2.101.0",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@fission-ai/openspec"
  ]
}
